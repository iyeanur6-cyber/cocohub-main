{
  "name": "cocohub-mobile",
  "version": "1.0.0",
  "description": "Cocohub — Secure pet health records, medication reminders, QR scanning, and emergency SOS, all powered by blockchain verification.",
  "author": "Cocohub, Inc. <support@cocohub.app> (https://cocohub.app)",
  "homepage": "https://cocohub.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/DogStark/Cocohub-MobileApp.git"
  },
  "license": "MIT",
  "keywords": [
    "pet",
    "health",
    "medical-records",
    "blockchain",
    "qr-scanner",
    "medication-reminders",
    "vet",
    "pet-care",
    "pet-tracker",
    "react-native",
    "expo",
    "stellar"
  ],
  "scripts": {
    "start": "APP_ENV=development expo start",
    "start:staging": "APP_ENV=staging expo start",
    "start:production": "APP_ENV=production expo start",
    "eas:build:dev": "eas build --platform all --profile development",
    "eas:build:preview": "eas build --platform all --profile preview",
    "eas:build:staging": "eas build --platform all --profile staging",
    "eas:build:prod": "eas build --platform all --profile production",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --ci --coverage",
    "test:snapshots:update": "jest --runInBand --updateSnapshot",
    "test:snapshots": "jest --runInBand --testPathPattern='snapshot\\.test'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e:test": "maestro test .maestro/flows/smoke-test.yaml",
    "prepare": "husky",
    "codegen": "graphql-codegen --config codegen.ts",
    "migrations:validate": "tsx scripts/validate-migrations.ts",
    "check:empty-tests": "tsx scripts/check-empty-test-files.ts",
    "test:migrations": "tsx scripts/test-migrations.ts",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "tsx scripts/generate-openapi.ts --check",
    "openapi:validate": "tsx scripts/validate-openapi-schema.ts",
    "migrate": "ts-node backend/src/db/migrate.ts",
    "seed": "ts-node backend/seeds/index.ts",
    "seed:dev": "ts-node backend/seeds/index.ts --owners 5 --vets 3 --pets 2 --records 3 --appointments 2 --medications 1",
    "seed:test": "ts-node backend/seeds/index.ts --cleanup --owners 2 --vets 1 --pets 1 --records 1 --appointments 1 --medications 1",
    "seed:large": "ts-node backend/seeds/index.ts --owners 20 --vets 10 --pets 3 --records 5 --appointments 3 --medications 2",
    "server": "tsx backend/server/index.ts",
    "dev:docker": "docker-compose up",
    "audit:high": "npm audit --audit-level=high",
    "storybook:ci": "npx sb-rn-get-stories"
  },
  "lint-staged": {
    "{src,backend}/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=-1",
      "prettier --write"
    ],
    "{src,backend}/**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=-1",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@apollo/server": "^4.12.2",
    "@elastic/elasticsearch": "^9.4.2",
    "@expo/metro-runtime": "^56.0.15",
